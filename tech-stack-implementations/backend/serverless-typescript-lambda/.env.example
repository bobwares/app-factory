# AWS Configuration (for local development)
AWS_REGION=us-east-1
AWS_PROFILE=default

# Application
LOG_LEVEL=DEBUG
POWERTOOLS_SERVICE_NAME=serverless-typescript-lambda
POWERTOOLS_METRICS_NAMESPACE=ServerlessApp

# DynamoDB (local)
TABLE_NAME=serverless-typescript-lambda-items

# JWT (for local testing)
JWT_ISSUER=https://your-auth-provider.com
JWT_AUDIENCE=your-api-audience
