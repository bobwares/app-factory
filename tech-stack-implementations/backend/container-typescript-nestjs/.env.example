# Application
NODE_ENV=local
PORT=3000
HOST=0.0.0.0

# Logging
LOG_LEVEL=debug

# Authentication
JWT_SECRET=your-jwt-secret-here
JWT_ISSUER=your-issuer
BYPASS_AUTH=true

# OpenTelemetry
OTEL_SERVICE_NAME=container-typescript-nestjs
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# CORS
CORS_ORIGIN=http://localhost:4200
